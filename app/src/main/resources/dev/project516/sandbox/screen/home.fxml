<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ComboBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.project516.sandbox.screen.HomeController">
    <children>
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="390.0" minWidth="10.0" prefWidth="307.0" />
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="671.0" minWidth="10.0" prefWidth="375.0" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="555.0" minWidth="10.0" prefWidth="179.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
              <Button fx:id="launchButton" onAction="#onLaunchClick" prefHeight="30.0" prefWidth="195.0" text="Launch" />
              <Button fx:id="quitButton" onAction="#onQuitClick" prefHeight="26.0" prefWidth="116.0" text="Quit" GridPane.columnIndex="2" />
             <Button fx:id="iconButton" mnemonicParsing="false" onAction="#onSetIconClick" prefHeight="26.0" prefWidth="116.0" text="Set Icon" GridPane.columnIndex="2" GridPane.rowIndex="1" />
             <Button fx:id="settingsButton" onAction="#onSettingsClick" prefHeight="26.0" prefWidth="116.0" text="Settings" GridPane.columnIndex="2" GridPane.rowIndex="2" />
             <Button fx:id="fabricButton" mnemonicParsing="false" onAction="#onInstallFabricClick" prefHeight="26.0" prefWidth="116.0" text="Install Fabric" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <Button fx:id="addTestButton" mnemonicParsing="false" onAction="#onAddClick" prefHeight="26.0" prefWidth="217.0" text="Add Instance" GridPane.columnIndex="1" />
            <Button fx:id="deleteTestButton" mnemonicParsing="false" onAction="#onDeleteClick" prefHeight="26.0" prefWidth="216.0" text="Delete Instance" GridPane.columnIndex="1" GridPane.rowIndex="1" />
             <Button fx:id="renameButton" mnemonicParsing="false" onAction="#onRenameClick" prefHeight="26.0" prefWidth="216.0" text="Rename Instance" GridPane.columnIndex="1" GridPane.rowIndex="2" />
             <ComboBox fx:id="versionComboBox" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <ListView fx:id="instanceListView" prefHeight="200.0" prefWidth="200.0" />
    </children>
</VBox>
