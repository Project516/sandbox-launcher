<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.project516.sandbox.screen.ConsoleController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <TextArea fx:id="consoleArea" prefHeight="400.0" prefWidth="600.0" editable="false" style="-fx-font-family: monospace; -fx-control-inner-background: #1e1e1e; -fx-text-fill: #cccccc;" />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="killButton" onAction="#onKillClick" text="Kill Process" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
        <Button fx:id="closeButton" onAction="#onCloseClick" text="Close" />
    </HBox>
</VBox>