<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="150.0" prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.project516.sandbox.screen.SettingsController">
    <children>
        <Label text="Settings" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <HBox alignment="CENTER" spacing="10.0">
            <Label text="Username:" />
            <TextField fx:id="usernameField" prefWidth="150" />
        </HBox>

        <HBox alignment="CENTER" spacing="10.0">
            <Button fx:id="saveButton" onAction="#onSaveClick" text="Save" />
            <Button fx:id="cancelButton" onAction="#onCancelClick" text="Cancel" />
        </HBox>
    </children>
</VBox>